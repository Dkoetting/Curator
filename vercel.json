{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/cron-morning-dach",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron-evening-us-apac",
      "schedule": "30 17 * * *"
    },
    {
      "path": "/api/cron-projektstatus-sync",
      "schedule": "0 19 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/app",
      "destination": "/",
      "permanent": false
    }
  ]
}
